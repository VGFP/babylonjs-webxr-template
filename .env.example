# ── Deployment ──────────────────────────────────────────────
# Your deployed PWA domain (no trailing slash, no protocol)
HOST=example.com
# Full URL to your deployed manifest.webmanifest
MANIFEST_URL=https://example.com/manifest.webmanifest
# Path prefix for the app on your server (e.g. /my-app/ or /)
START_URL=/

# ── App Identity ───────────────────────────────────────────
APP_NAME="BabylonJS WebXR"
SHORT_NAME="BabylonXR"
PKG_NAME=com.devlocal.babylonxr
APP_VERSION=1.0.0
APP_VERSION_CODE=1

# ── Keystore / Signing ────────────────────────────────────
KEYSTORE_PATH=
KEY_ALIAS=androiddebugkey
STORE_PASSWORD=android
KEY_PASSWORD=android

# ── SDK Paths ──────────────────────────────────────────────
JAVA_HOME=
ANDROID_SDK_ROOT=

# ── Build Output ───────────────────────────────────────────
OUTPUT_DIR=./dist-apk
