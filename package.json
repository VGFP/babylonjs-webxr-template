{
  "name": "babylonjs-webxr-template",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "debug": "vite --mode debug",
    "dev:server": "pnpm --dir server install && pnpm --dir server exec vite",
    "dev:full": "concurrently -n client,server -c blue,green \"pnpm dev\" \"pnpm dev:server\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format && pnpm typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babylonjs/addons": "^9.13.0",
    "@babylonjs/core": "^9.13.0",
    "@babylonjs/gui": "^9.13.0",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/inspector": "^9.13.0",
    "@babylonjs/loaders": "^9.13.0",
    "@babylonjs/materials": "^9.13.0",
    "@colyseus/schema": "4.0.26",
    "@colyseus/sdk": "0.17.42",
    "earcut": "^3.0.2",
    "onnxruntime-web": "1.18.0",
    "openai": "^6.42.0",
    "pdfjs-dist": "^6.0.227",
    "pnpm": "^11.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/earcut": "^3.0.0",
    "@types/node": "^25.8.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
