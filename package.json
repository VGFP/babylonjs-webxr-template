{
  "name": "babylonjs-webxr-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babylonjs/addons": "^9.7.0",
    "@babylonjs/core": "^9.7.0",
    "@babylonjs/gui": "^9.7.0",
    "@babylonjs/inspector": "^9.7.0",
    "@babylonjs/loaders": "^9.7.0",
    "@babylonjs/materials": "^9.7.0",
    "earcut": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/earcut": "^3.0.0",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "zod": "^4.4.3"
  }
}
